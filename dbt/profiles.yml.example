# Copy to ~/.dbt/profiles.yml (outside the repo — never commit with real credentials)

ais_databricks:
  target: dev
  outputs:
    dev:
      type: databricks
      host:       "{{ env_var('DATABRICKS_HOST') }}"
      http_path:  "{{ env_var('DATABRICKS_HTTP_PATH') }}"
      token:      "{{ env_var('DATABRICKS_TOKEN') }}"
      catalog:    hive_metastore
      schema:     default
      threads: 4

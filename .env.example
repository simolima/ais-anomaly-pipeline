# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Databricks ────────────────────────────────────────────────────────────────
DATABRICKS_HOST=https://<your-workspace>.azuredatabricks.net
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>
DATABRICKS_CATALOG=hive_metastore
DATABRICKS_SCHEMA=default

# ── OpenSanctions ─────────────────────────────────────────────────────────────
OPENSANCTIONS_API_KEY=your_free_api_key_here

# ── Email alerts (Gmail SMTP) ─────────────────────────────────────────────────
# Use a dedicated Gmail account, not your personal one.
# Enable "App Passwords" in Google Account > Security.
ALERT_EMAIL_FROM=your-alert-account@gmail.com
ALERT_EMAIL_PASSWORD=your-app-password-here
ALERT_EMAIL_TO=your-email@example.com
